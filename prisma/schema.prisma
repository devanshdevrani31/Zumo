generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  orgId        String
  role         String   @default("admin")
  createdAt    DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id])
}

model Organization {
  id                  String   @id @default(cuid())
  name                String
  dataRegion          String   @default("EU")
  dailySpendCap       Float    @default(100.0)
  perEmployeeSpendCap Float    @default(25.0)
  hardStopBehavior    String   @default("pause")
  retentionDays       Int      @default(90)
  onboardingCompleted Boolean  @default(false)
  createdAt           DateTime @default(now())

  users             User[]
  employees         Employee[]
  policies          Policy[]
  approvalRequests  ApprovalRequest[]
  auditLogs         AuditLog[]
  teams             Team[]
  providerConfigs   ProviderConfig[]
  connectedAccounts ConnectedAccount[]
}

model ProviderConfig {
  id           String   @id @default(cuid())
  orgId        String
  type         String
  provider     String
  mode         String
  credentials  String   @default("")
  plan         String   @default("")
  region       String   @default("")
  status       String   @default("active")
  costEstimate Float    @default(0)
  createdAt    DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id])
}

model ConnectedAccount {
  id             String   @id @default(cuid())
  orgId          String
  connector      String
  scopes         String   @default("[]")
  riskLevel      String   @default("low")
  writeEnabled   Boolean  @default(false)
  tokenEncrypted String   @default("")
  status         String   @default("connected")
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id])
}

model Employee {
  id            String    @id @default(cuid())
  name          String
  role          String
  runtime       String    @default("openclaw")
  modelProvider String    @default("anthropic")
  tools         String    @default("[]")
  autonomyMode  String    @default("assist")
  instructions  String    @default("")
  status        String    @default("running")
  teamId        String?
  orgId         String?
  serverId      String?
  softDeleted   Boolean   @default(false)
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  team             Team?             @relation(fields: [teamId], references: [id])
  organization     Organization?     @relation(fields: [orgId], references: [id])
  policies         Policy[]
  approvalRequests ApprovalRequest[]
  auditLogs        AuditLog[]
}

model Policy {
  id         String  @id @default(cuid())
  employeeId String
  capability String
  permission String  @default("allow")
  rateLimit  Int?
  orgId      String?

  employee     Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [orgId], references: [id])
}

model ApprovalRequest {
  id         String    @id @default(cuid())
  employeeId String
  action     String
  details    String    @default("")
  diff       String    @default("")
  status     String    @default("pending")
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?
  orgId      String?

  employee     Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [orgId], references: [id])
}

model AuditLog {
  id           String   @id @default(cuid())
  employeeId   String?
  action       String
  details      String   @default("")
  hash         String
  previousHash String
  timestamp    DateTime @default(now())
  orgId        String?

  employee     Employee?     @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  organization Organization? @relation(fields: [orgId], references: [id])
}

model Team {
  id          String  @id @default(cuid())
  name        String
  description String  @default("")
  orgId       String?

  organization  Organization?  @relation(fields: [orgId], references: [id])
  employees     Employee[]
  workflowRules WorkflowRule[]
}

model WorkflowRule {
  id      String @id @default(cuid())
  teamId  String
  trigger String
  steps   String @default("[]")

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
}
